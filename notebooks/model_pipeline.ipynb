    "import numpy as np\n",
    "class LabelEncoderr():\n",
    "    def __init__(self):\n",
    "        self.encoder = LabelEncoder()\n",
    "    def fit(self, x, y=0):\n",
    "        self.encoder.fit(x)\n",
    "        return self\n",
    "    def transform(self, x, y=0):\n",
    "        return self.encoder.transform(x).reshape(-1, 1)\n"
   ]
